<Window x:Class="Group4337.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Group4337"
        mc:Ignorable="d"
        Title="Инструментальные Средства Разработки Программного Обеспечения" 
        Height="700" 
        Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Студент группы 4337 Казаков"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="15px" 
                       Grid.Row="0" />
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10" VerticalAlignment="Center" >
            <Button x:Name="btnImport" Content="Импорт данных" Width="120" Height="30" Margin="5" Click="btnImport_Click"/>
            <Button x:Name="btnExport" Content="Экспорт в Excel" Width="120" Height="30" Margin="5" Click="btnExport_Click"/>
            <TextBlock x:Name="txtStatus" Text="Готов к работе" VerticalAlignment="Center"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgEmployees" AutoGenerateColumns="True" Margin="0,0,0,10"/>
    </Grid>
</Window>